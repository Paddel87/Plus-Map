{
  "title": "Application",
  "description": "Application document replicated via /api/sync/applications. Wire-format contract shared with backend Pydantic ApplicationDoc (ADR-031). v1 added restraint_type_ids[] (M7.5, ADR-046).",
  "version": 1,
  "primaryKey": "id",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "maxLength": 36
    },
    "event_id": {
      "type": "string",
      "format": "uuid",
      "maxLength": 36
    },
    "performer_id": {
      "type": "string",
      "format": "uuid"
    },
    "recipient_id": {
      "type": "string",
      "format": "uuid"
    },
    "arm_position_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "hand_position_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "hand_orientation_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000000,
      "multipleOf": 1
    },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "ended_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "note": {
      "type": ["string", "null"]
    },
    "created_by": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "maxLength": 32
    },
    "deleted_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "_deleted": {
      "type": "boolean"
    },
    "restraint_type_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid",
        "maxLength": 36
      },
      "default": []
    }
  },
  "required": [
    "id",
    "event_id",
    "performer_id",
    "recipient_id",
    "sequence_no",
    "created_at",
    "updated_at"
  ],
  "indexes": [
    ["event_id", "sequence_no"],
    ["updated_at", "id"]
  ]
}
