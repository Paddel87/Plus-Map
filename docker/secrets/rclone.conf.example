# rclone config for HC-Map backups (M10.6, ADR-051 §D).
#
# This file is mounted into the backup container as a docker secret at
# /run/secrets/rclone.conf. The backup script reads it via
# `rclone --config /run/secrets/rclone.conf rcat ...`.
#
# Pick exactly ONE of the templates below, set HCMAP_BACKUP_REMOTE in
# .env.prod to the matching section name (without the colon), and rename
# this file to docker/secrets/rclone.conf.
#
# HC-Map gives no anbieter-vorgabe — see ops/runbook.md (M10.8) for an
# anbieter-walkthrough (Hetzner Storage Box, Backblaze B2, generic S3).

# ─── Template A: Hetzner Storage Box via SFTP ────────────────────────────
# [hetzner]
# type = sftp
# host = u123456.your-storagebox.de
# user = u123456
# pass = OBSCURED_VIA_RCLONE_OBSCURE
# # generate `pass` with: rclone obscure '<your-password>'

# ─── Template B: Backblaze B2 ────────────────────────────────────────────
# [b2]
# type = b2
# account = 0014a1b2c3d4e5f6
# key     = K001abcdefghijklmnopqrstuvwxyz0123456789

# ─── Template C: Generic S3 (AWS, MinIO, Wasabi, …) ──────────────────────
# [s3]
# type     = s3
# provider = AWS                  # or Minio, Wasabi, Other, …
# access_key_id     = AKIA...
# secret_access_key = wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# region   = eu-central-1
# endpoint =                      # leave empty for AWS; set for MinIO/Wasabi

# ─── Template D: Local filesystem (lab / restore-drill only) ─────────────
# [local]
# type = local
