# Plus-Map environment variables.
# Copy to .env (gitignored) and adjust for your local setup.
#
# Production uses the same names; secrets MUST be different in production.
# The HCMAP_* variable prefix is kept internal for backwards-compatibility
# of the configuration loader; it is not exposed to end users.

# --- Postgres / PostGIS ---------------------------------------------------
HCMAP_DB_USER=hcmap
HCMAP_DB_PASSWORD=hcmap
HCMAP_DB_NAME=hcmap

# --- Backend (FastAPI) ----------------------------------------------------
# environment: development | test | production
HCMAP_ENVIRONMENT=development
# log_level: DEBUG | INFO | WARNING | ERROR
HCMAP_LOG_LEVEL=INFO
# Async SQLAlchemy DSN. Container-internal hostname is "db".
HCMAP_DATABASE_URL=postgresql+asyncpg://hcmap:hcmap@db:5432/hcmap

# --- Auth / Session (M2) -------------------------------------------------
# Required: at least 32 characters, kept secret; rotates session validity.
HCMAP_SECRET_KEY=change-me-in-production-32-bytes-minimum-aaaaa
# In production keep cookie_secure=true (HTTPS-only). Set to false for local
# HTTP dev. Cookies: hcmap_session (HttpOnly, JWT) + hcmap_csrf (readable).
HCMAP_COOKIE_SECURE=true
# Session lifetime in seconds (default 7 days = 604800).
HCMAP_COOKIE_LIFETIME_SECONDS=604800
# Argon2id parameters (defaults follow OWASP 2024 recommendation).
HCMAP_ARGON2_TIME_COST=2
HCMAP_ARGON2_MEMORY_COST=19456
HCMAP_ARGON2_PARALLELISM=1

# --- Bootstrap (one-off) -------------------------------------------------
# Optional defaults for `python -m scripts.bootstrap_admin`. Email and
# password can also be passed as CLI flags.
# HCMAP_BOOTSTRAP_EMAIL=admin@example.com
# HCMAP_BOOTSTRAP_PASSWORD=change-me-12-chars-or-more
# HCMAP_BOOTSTRAP_NAME=Admin

# --- Tile provider (M5a, ADR-022) ----------------------------------------
# MapTiler Cloud API key. Server-side only — never exposed to the browser.
# Empty string disables the tile proxy and returns 503 from /api/tiles/*.
# The same key is reused by the geocoding proxy (M6.1, ADR-041 §B).
HCMAP_MAPTILER_API_KEY=
# MapTiler style identifier; basic-v2 is on the free tier.
HCMAP_MAPTILER_STYLE=basic-v2

# --- Geocoding rate limit (M6.1, ADR-041 §D) -----------------------------
# Per-user in-memory token-bucket limit for /api/geocode (rolling 60 s
# window). 0 disables the limiter entirely. Adjust if the group grows or
# you observe legitimate users hitting 429.
HCMAP_GEOCODE_RATE_PER_MINUTE=30

# --- Frontend (Next.js, M5a.3) -------------------------------------------
# Public tile URL template used by the LocationPickerMap and MapView.
# Default points at the same-origin tile proxy from M5a.1, which forwards
# to MapTiler with the server-side HCMAP_MAPTILER_API_KEY. Override only
# when pointing at a self-hosted tileserver (M12) or a different proxy.
NEXT_PUBLIC_TILE_URL=/api/tiles/{z}/{x}/{y}
# Default map center when GPS is unavailable (Berlin city center).
# Format: "lat,lon".
NEXT_PUBLIC_DEFAULT_MAP_CENTER=52.5200,13.4050
# Server-side backend URL for Next.js SSR fetches (M11-HOTFIX-001, ADR-053).
# Read at request time from process.env, never sent to the browser. The
# compose default points at the in-network backend container hostname; this
# variable is only relevant if your reverse-proxy/compose topology changes
# how the frontend container reaches the backend (e.g. external reverse-proxy
# running outside the compose network — see ops/runbook.md §4.3).
BACKEND_INTERNAL_URL=http://backend:8000

# --- SMTP / Mail (M10.2, ADR-051 §C) -------------------------------------
# HC-Map sends two kinds of mail: password-reset and (future) email-verify.
# Leave HCMAP_SMTP_HOST empty in development — the LoggingBackend writes the
# reset URL to the structured log instead. Set the host (and HCMAP_SMTP_FROM)
# to switch the production backend on.
HCMAP_SMTP_HOST=
HCMAP_SMTP_PORT=587
HCMAP_SMTP_USER=
HCMAP_SMTP_PASSWORD=
# Port 587 with STARTTLS is the typical submission setup. Use 465 + use_tls=true
# for implicit-TLS providers; STARTTLS and use_tls are mutually exclusive.
HCMAP_SMTP_STARTTLS=true
HCMAP_SMTP_USE_TLS=false
# Required when HCMAP_SMTP_HOST is set.
HCMAP_SMTP_FROM=
HCMAP_SMTP_FROM_NAME=HC-Map

# --- Public base URL (M10.2, ADR-051 §C) ---------------------------------
# Used to build links in outgoing mail (e.g. password-reset links).
# Set to the public origin of the frontend, NOT the backend.
HCMAP_BASE_URL=http://localhost:3000

# =========================================================================
# Production / Reverse-Proxy block (M10.5, ADR-051 §B/§F)
# =========================================================================
# Only relevant when running docker/compose.prod.yml. Copy this file to
# .env.prod (gitignored) and replace every placeholder. Keep the .env above
# untouched for local Docker-Compose dev.
#
# The reverse-proxy is added by composing one of the overlays:
#   docker compose -f docker/compose.prod.yml -f docker/compose.caddy.yml \
#     --env-file .env.prod up -d
#   (or compose.traefik.yml for Traefik). See ops/runbook.md (M10.8).

# --- Domain / TLS / Reverse Proxy ----------------------------------------
# Public hostname that resolves to this server (DNS A/AAAA). The reverse
# proxy obtains a Let's Encrypt cert for this name on first request.
HCMAP_DOMAIN=hc-map.example.org
# Contact for the Let's Encrypt registration. Only the proxy uses it.
HCMAP_ACME_EMAIL=admin@example.org
# Optional cookie domain. Empty = host-only cookie (recommended). Set this
# to ".example.org" only if you need to share the session across subdomains.
HCMAP_COOKIE_DOMAIN=

# --- Image tag (M10.7) ---------------------------------------------------
# Pinned image tag pulled from ghcr.io/paddel87/hc-map-{backend,frontend}.
# Use ":rc" for rolling release-candidate builds, ":0.1.0-rc.1" once
# tagged, or ":0.1.0" after RC promotion. ":latest" is reserved for
# stable final releases (set automatically by CI from M10.7 onward).
# Note: docker/metadata-action's `v{{version}}` semver pattern strips the
# leading `v` from the git tag — git tag is `v0.1.0-rc.1`, GHCR tag is
# `0.1.0-rc.1` (no v). The `:rc` rolling channel always points at the
# current RC build and is the safest pin for first-time operators.
HCMAP_IMAGE_TAG=rc

# --- Migrations ----------------------------------------------------------
# The backend container runs `alembic upgrade head` once on startup,
# guarded by a Postgres advisory lock so a second instance cannot race it
# (ADR-051 §F). Set to 1 only for emergency rollbacks where you need to
# start the backend without applying pending migrations.
HCMAP_SKIP_MIGRATIONS=0

# --- Backup target (M10.6) -----------------------------------------------
# The backup service runs `pg_dump | age | rclone rcat` on a cron schedule
# (daily 03:17 UTC, weekly Sun 03:33, monthly 1st 03:47; retention sweep
# 04:00 daily — 14d / 56d / 365d). Required for compose.prod.yml to come
# up. See ops/runbook.md (M10.8) for the rclone + age key walk-through.
#
# HCMAP_BACKUP_REMOTE   rclone remote name (matches a [section] header in
#                       docker/secrets/rclone.conf), e.g. "hetzner".
# HCMAP_BACKUP_PREFIX   path prefix on that remote, e.g. "hc-map" (yields
#                       hetzner:hc-map/daily/<ts>.dump.age and so on).
# HCMAP_BACKUP_RUN_ON_START
#                       set to 1 to run an immediate daily backup when
#                       the container starts. Useful for the first
#                       restore-drill; leave at 0 for normal operation.
#
# Recipients (age public keys) live in docker/secrets/age-recipients.txt
# and are mounted as a docker secret — they are NOT environment variables.
HCMAP_BACKUP_REMOTE=
HCMAP_BACKUP_PREFIX=hc-map
HCMAP_BACKUP_RUN_ON_START=0

# --- Plus-Map Traefik-Overlay (Variante A in der README) -----------------
# Wird ausschliesslich vom docker/compose.plus-map.traefik.yml-Overlay
# verwendet. Im Standalone-Pfad (compose.plus-map.yml allein) ignoriert.
#
# PLUS_MAP_DOMAIN          z. B. plus-map.example.org
# TRAEFIK_NETWORK          Name des extern markierten Traefik-Netzwerks
#                          (`docker network ls` auf dem Host zeigt alle
#                          Kandidaten; typische Namen: traefik,
#                          traefik-public, web).
# TRAEFIK_CERTRESOLVER     certresolver-Name in der Traefik-Konfig.
# TRAEFIK_ENTRYPOINT       Traefik-Entrypoint-Name (i. d. R. websecure).
PLUS_MAP_DOMAIN=
TRAEFIK_NETWORK=traefik
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_ENTRYPOINT=websecure
